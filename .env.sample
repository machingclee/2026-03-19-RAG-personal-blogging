# FastAPI RAG Lambda Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control (it's in .gitignore)

# App Settings
APP_NAME=

# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_API_VERSION=
AZURE_OPENAI_MODEL=

# Pushover Notifications (optional)
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=

# SendGrid Email (optional)
SENDGRID_API_KEY=

# LangSmith Tracing (optional)
LANGSMITH_TRACING=
LANGSMITH_ENDPOINT=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# Serper Search API (optional)
SERPER_API_KEY=

# PostgreSQL/Neon Vector Database (Required)
POSTGRES_HOST=
POSTGRES_DATABASE=
POSTGRES_USER=
POSTGRES_PASSWORD=
